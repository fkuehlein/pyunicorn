@article{sales_pynamicalsys_2025,
	title = {pynamicalsys: {A} {Python} toolkit for the analysis of dynamical systems},
	volume = {201},
	issn = {0960-0779},
	shorttitle = {pynamicalsys},
	url = {https://www.sciencedirect.com/science/article/pii/S0960077925012822},
	doi = {10.1016/j.chaos.2025.117269},
	abstract = {Since Lorenz’s seminal work on a simplified weather model, the numerical analysis of nonlinear dynamical systems has become one of the main subjects of research in physics. Despite of that, there remains a need for accessible, efficient, and easy-to-use computational tools to study such systems. In this paper, we introduce , a simple yet powerful open-source Python module for the analysis of nonlinear dynamical systems. In particular, implements tools for trajectory simulation, bifurcation diagrams, Lyapunov exponents and several others chaotic indicators, period orbit detection and their manifolds, as well as escape and basins analysis. We demonstrate the capabilities of through a series of examples that reproduces well-known results in the literature while developing the mathematical analysis at the same time. We also provide the Jupyter notebook containing all the code used in this paper, including performance benchmarks. is freely available via the Python Package Index (PyPI) and is intended to support both research and teaching in nonlinear dynamics.},
	urldate = {2026-03-17},
	journal = {Chaos, Solitons \& Fractals},
	author = {Sales, Matheus Rolim and de Souza, Leonardo Costa and Borin, Daniel and Mugnaine, Michele and Szezech, José Danilo and Viana, Ricardo Luiz and Caldas, Iberê Luiz and Leonel, Edson Denis and Antonopoulos, Chris G.},
	month = dec,
	year = {2025},
	keywords = {Python package, Chaos theory, Nonlinear dynamical systems},
	pages = {117269},
	file = {ScienceDirect Full Text PDF:/home/fritzku/Zotero/storage/KM5EX8LD/Sales et al. - 2025 - pynamicalsys A Python toolkit for the analysis of dynamical systems.pdf:application/pdf;ScienceDirect Snapshot:/home/fritzku/Zotero/storage/AIDQZK8V/S0960077925012822.html:text/html},
}

